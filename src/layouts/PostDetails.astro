---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

export interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title, author, description,
  ogImage: initOgImage, canonicalURL,
  pubDatetime, modDatetime, timezone, tags, faq = [],
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") ogImageUrl = initOgImage;
else if (initOgImage?.src) ogImageUrl = initOgImage.src;
if (!ogImageUrl && SITE.dynamicOgImage) ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
const ogImage = ogImageUrl ? new URL(ogImageUrl, Astro.url.origin).href : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author, description, pubDatetime, modDatetime, canonicalURL, ogImage,
  scrollSmooth: true,
};

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({ id, title, filePath }));
const idx = allPosts.findIndex(a => a.id === post.id);
const prevPost = idx > 0 ? allPosts[idx - 1] : null;
const nextPost = idx >= 0 && idx < allPosts.length - 1 ? allPosts[idx + 1] : null;

const faqSchema = faq.length
  ? { "@context": "https://schema.org", "@type": "FAQPage",
      mainEntity: faq.map(item => ({ "@type": "Question", name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer } })) }
  : null;
---

<Layout {...layoutProps}>
  <Header />

  <div class="grid">
    <main id="main-content" class="content" data-pagefind-body>
      <a href="/posts" class="back-link">← All writing</a>

      <h1
        transition:name={slugifyStr(title)}
        class="post-title"
      >{title}</h1>

      <div class="post-meta">
        <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      </div>

      <article id="article" class="prose">
        <Content />
      </article>

      {faqSchema && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
      )}

      <hr />

      {tags && tags.length > 0 && (
        <ul class="tag-list">
          {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} />)}
        </ul>
      )}

      <nav class="prev-next" aria-label="Previous and next post">
        {prevPost ? (
          <a href={getPath(prevPost.id, prevPost.filePath)} class="prev-next__item">
            <span class="lbl">← Previous</span>
            <span class="ttl">{prevPost.title}</span>
          </a>
        ) : <span />}
        {nextPost ? (
          <a href={getPath(nextPost.id, nextPost.filePath)} class="prev-next__item prev-next__item--right">
            <span class="lbl">Next →</span>
            <span class="ttl">{nextPost.title}</span>
          </a>
        ) : <span />}
      </nav>

      <Footer />
    </main>
  </div>
</Layout>

<style>
  .back-link {
    display: inline-block;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 64px;
  }
  .back-link:hover { color: var(--accent); }

  .post-title {
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: 12px;
    max-width: 24ch;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
  }

  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 64px;
  }
  .prev-next__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .prev-next__item--right {
    text-align: right;
    align-items: flex-end;
  }
  .prev-next__item .lbl {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
  }
  .prev-next__item .ttl {
    font-size: 16px;
    color: var(--ink);
    line-height: 1.3;
  }
  .prev-next__item:hover .ttl { color: var(--accent); }

  @media (max-width: 720px) {
    .prev-next { grid-template-columns: 1fr; }
    .prev-next__item--right { text-align: left; align-items: flex-start; }
  }
</style>

<script is:inline data-astro-rerun>
  function addHeadingLinks() {
    const hs = Array.from(document.querySelectorAll("article#article h2, article#article h3, article#article h4"));
    for (const h of hs) {
      if (!h.id) continue;
      h.classList.add("group");
      const a = document.createElement("a");
      a.href = "#" + h.id;
      a.className = "heading-link";
      a.setAttribute("aria-label", "Permalink");
      a.innerText = "#";
      h.appendChild(a);
    }
  }
  addHeadingLinks();

  function attachCopyButtons() {
    const blocks = Array.from(document.querySelectorAll("article#article pre"));
    for (const b of blocks) {
      const btn = document.createElement("button");
      btn.innerText = "Copy";
      btn.className = "copy-code";
      b.appendChild(btn);
      btn.addEventListener("click", async () => {
        const code = b.querySelector("code");
        await navigator.clipboard.writeText(code?.innerText ?? "");
        btn.innerText = "Copied";
        setTimeout(() => (btn.innerText = "Copy"), 800);
      });
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

<style is:global>
  .prose .heading-link {
    margin-left: 8px;
    opacity: 0;
    transition: opacity 140ms ease;
    border-bottom: 0;
    color: var(--muted);
  }
  .prose h2:hover .heading-link,
  .prose h3:hover .heading-link,
  .prose h4:hover .heading-link { opacity: 1; }
  .prose pre {
    position: relative;
  }
  .prose pre .copy-code {
    position: absolute;
    top: 8px;
    right: 8px;
    font-size: 11px;
    padding: 4px 8px;
    background: var(--bg);
    color: var(--muted);
    border: 1px solid var(--rule);
    border-radius: 3px;
    cursor: pointer;
    font-family: var(--font-stack);
  }
  .prose pre .copy-code:hover { color: var(--ink); border-color: var(--ink); }
</style>
