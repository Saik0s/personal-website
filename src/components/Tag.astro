---
export interface Props {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
}
const { tag, tagName, size = "sm" } = Astro.props;
---

<li class={size === "lg" ? "tag-li-lg" : "tag-li-sm"}>
  <a href={`/tags/${tag}/`} transition:name={tag} class="tag-chip">
    {tagName}
  </a>
</li>

<style>
  .tag-li-sm, .tag-li-lg {
    display: inline-block;
    list-style: none;
  }
  .tag-li-lg .tag-chip {
    font-size: 15px;
    padding: 8px 14px;
  }
</style>
