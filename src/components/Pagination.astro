---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
export interface Props { page: Page<CollectionEntry<"blog">>; }
const { page } = Astro.props;
---

{page.lastPage > 1 && (
  <nav class="pagination" aria-label="Pagination">
    <a
      href={page.url.prev ?? "#"}
      aria-disabled={!page.url.prev}
      aria-label="Previous"
    >← Prev</a>
    <span>{page.currentPage} / {page.lastPage}</span>
    <a
      href={page.url.next ?? "#"}
      aria-disabled={!page.url.next}
      aria-label="Next"
    >Next →</a>
  </nav>
)}
