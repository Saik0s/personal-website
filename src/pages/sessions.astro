---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hr from "@/components/Hr.astro";
import PickMyBrainButton from "@/components/PickMyBrainButton.astro";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "AI Shipping Consultancy",
  provider: {
    "@type": "Person",
    name: "Igor Tarasenko",
  },
  areaServed: "Worldwide",
  description:
    "Six-week AI shipping consultancy delivering PRs, evals, guardrails, monitoring, and handover-ready code.",
};
---

<Layout
  title="AI Shipping Consultancy"
  description="This offer has been consolidated into the AI Shipping Consultancy."
  structuredData={[serviceSchema]}
>
  <Header />
  <main id="main-content" class="mx-auto max-w-3xl px-4 py-16 space-y-8">
    <section class="space-y-4">
      <h1 class="text-3xl font-bold">This offer has moved.</h1>
      <p class="text-lg text-foreground/80">
        Sessions are now part of the AI Shipping Consultancy.
        If you need a production AI feature shipped, start with a discovery call.
      </p>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <PickMyBrainButton
          variant="pushable"
          duration="30min"
          text="Book a Discovery Call"
          eventName="Conversion: Consultancy Discovery Call"
          eventCategory="conversion"
          eventProps={{ service: "ai-shipping-consultancy", placement: "moved" }}
        />
      </div>
      <p class="text-sm text-foreground/70">
        Or read the full details on <a class="text-accent" href="/#offer">the homepage →</a>
      </p>
    </section>
    <Hr />
  </main>
  <Footer />
</Layout>
