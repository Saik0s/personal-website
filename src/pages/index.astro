---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getCollection } from "astro:content";
import { getPath } from "@/utils/getPath";

const posts = await getCollection("blog");

const findPath = (slug: string, fallback = "/posts") => {
  const match = posts.find(p => p.id === slug || p.id.endsWith(`/${slug}`));
  return match ? getPath(match.id, match.filePath) : fallback;
};

const writing = [
  {
    label: "Is Your Repo Ready for AI Agents?",
    href: findPath("is-your-repo-ready-for-ai-agents"),
  },
  {
    label: "If \u201cClear Tickets\u201d Belong to Agents, Where Is Your Edge?",
    href: findPath("agentic-engineering-solo-cell"),
  },
  {
    label: "How Sourcery Makes AI 10x More Useful in Large iOS Codebases",
    href: findPath("ios_codebase_context_sourcery"),
  },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Igor Tarasenko",
  jobTitle: "iOS and AI engineer",
  url: "https://tarasenko.dev",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Amsterdam",
    addressCountry: "NL",
  },
  sameAs: ["https://github.com/Saik0s", "https://x.com/saik0s"],
};
---

<Layout
  title="Igor Tarasenko"
  description="Igor Tarasenko, iOS and AI engineer based in Amsterdam. Writing about the part of an AI product that lives between a demo and production."
  structuredData={personSchema}
>
  <Header />

  <div class="grid">
    <main class="content">
      <section class="hero">
        <h1>
          <span class="br">Hi, I&rsquo;m Igor</span>
          <span class="br">Tarasenko.</span>
        </h1>

        <p>
          I&rsquo;m an iOS and AI engineer based in Amsterdam. Five years at
          Uber before that, on server-driven UI and then payments.
        </p>

        <p>
          These days I&rsquo;m in-house at a large enterprise SaaS company. iOS,
          the dev environment, and the agents the team runs in production. On
          the side:
          <a href="https://github.com/Saik0s/mcp-browser-use">mcp-browser-use</a>,
          an open-source MCP server for browser automation;
          <a href="https://apps.apple.com/app/whisperboard/id1661442906">WhisperBoard</a>,
          an on-device iOS Whisper app; and coaching senior engineers on
          <a href="https://www.codementor.io/@saik0s">Codementor</a>.
        </p>

        <p>
          I write about the part of an AI product that lives between a demo and
          production: evals, guardrails, agent loops, repo shape that
          doesn&rsquo;t fight the agent, dev environments where the agent can
          check its own work. I burn $10k a month on tokens learning what works
          and what doesn&rsquo;t.
        </p>

        <div class="timestamp">Last updated: May 2026</div>
      </section>

      <section>
        <h2 class="label">Selected writing</h2>
        <ol class="writing">
          {writing.map(item => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ol>
        <p class="all-writing"><a href="/posts">All writing &rarr;</a></p>
      </section>

      <section>
        <p class="proof">
          WhisperBoard 4.8&#9733; on the App Store<span class="dot">·</span>mcp-browser-use ~900 stars on GitHub<span class="dot">·</span>Codementor 5.0 across 30 sessions
        </p>

        <p class="closing">
          <a href="/work">Available for selected engagements <span class="arrow">&rarr;</span></a>
        </p>
      </section>

      <Footer />
    </main>
  </div>
</Layout>
