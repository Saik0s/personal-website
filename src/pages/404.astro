---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`404 | ${SITE.title}`}>
  <Header />
  <div class="grid">
    <main id="main-content" class="content">
      <p class="kicker">404</p>
      <h1 class="page-h1">Nothing here.</h1>
      <p class="page-lede">
        The page moved, was renamed, or was never written. <a href="/" style="color:var(--accent);border-bottom:1px solid currentColor;">Go home</a> or <a href="/posts" style="color:var(--accent);border-bottom:1px solid currentColor;">read something</a>.
      </p>
      <Footer />
    </main>
  </div>
</Layout>

<style>
  .kicker {
    font-family: var(--font-mono-stack);
    color: var(--accent);
    font-size: 14px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
</style>
